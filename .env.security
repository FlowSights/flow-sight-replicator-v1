# Configuración de Seguridad - FlowSights
# Este archivo documenta las configuraciones de seguridad aplicadas

# CORS - Dominios permitidos
VITE_ALLOWED_ORIGINS=https://flowsights.it.com,https://www.flowsights.it.com,http://localhost:5173

# Validación de Contraseñas
VITE_PASSWORD_MIN_LENGTH=8
VITE_PASSWORD_REQUIRE_UPPERCASE=true
VITE_PASSWORD_REQUIRE_NUMBERS=true

# Límites de Entrada
VITE_MAX_NAME_LENGTH=100
VITE_MAX_EMAIL_LENGTH=255
VITE_MAX_COMPANY_LENGTH=150
VITE_MAX_MESSAGE_LENGTH=2000
VITE_MAX_PHONE_LENGTH=20

# Rate Limiting (para implementación futura)
VITE_RATE_LIMIT_ENABLED=false
VITE_RATE_LIMIT_REQUESTS=10
VITE_RATE_LIMIT_WINDOW_MS=60000

# Seguridad de Sesión
VITE_SESSION_TIMEOUT_MS=3600000
VITE_SESSION_REFRESH_BEFORE_EXPIRY_MS=300000

# CSP - Content Security Policy (configurar en Vercel)
# default-src 'self'
# script-src 'self' https://*.supabase.co https://*.googleapis.com
# style-src 'self' https://fonts.googleapis.com
# img-src 'self' data: https://*.supabase.co https://*.googleapis.com https://storage.googleapis.com
# font-src 'self' https://fonts.gstatic.com
# connect-src 'self' https://*.supabase.co https://*.googleapis.com https://api.stripe.com
# frame-src 'self' https://checkout.stripe.com https://js.stripe.com
# frame-ancestors 'self'
# upgrade-insecure-requests

# Logging de Seguridad
VITE_SECURITY_LOG_ENABLED=true
VITE_SECURITY_LOG_LEVEL=warn

# Feature Flags de Seguridad
VITE_ENABLE_2FA=false
VITE_ENABLE_IP_WHITELIST=false
VITE_ENABLE_DEVICE_FINGERPRINT=false
